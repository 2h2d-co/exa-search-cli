{
  "name": "exa-search-cli",
  "version": "0.0.1-alpha.2",
  "description": "An unofficial zero-runtime-dependency CLI for the Exa Search API",
  "homepage": "https://github.com/2h2d-co/exa-search-cli#readme",
  "bugs": {
    "url": "https://github.com/2h2d-co/exa-search-cli/issues"
  },
  "license": "MIT",
  "author": "Kaan Ozdokmeci",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2h2d-co/exa-search-cli.git"
  },
  "bin": {
    "exa-search": "bin/exa-search.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test --test-concurrency=1 test/*.test.ts",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@types/node": "^24",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6"
  },
  "engines": {
    "node": ">=24"
  }
}
